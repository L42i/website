---
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  // only people with has_page: true get a route — right now that's just Tristan
  const people = await getCollection('people', ({ data }) => data.has_page);
  return people.map((person) => ({
    params: { id: person.id },
    props: { person },
  }));
}

const { person } = Astro.props;
const { Content } = await render(person);
---

<article>
  <h1>{person.data.name}</h1>
  <p>{person.data.role}</p>
  {person.data.img && <img src={person.data.img} alt={person.data.name} />}
  <Content />
  {person.data.website && (
    <p><a href={person.data.website} target="_blank">Website ↗</a></p>
  )}
</article>