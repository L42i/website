---
// Import all files
const allPages = import.meta.glob('../pages/**/*.md', { eager: true });
const pages = Object.values(allPages);

// Get current category from URL
const currentPath = Astro.url.pathname;
const category = currentPath.split('/')[1];

// Filter pages that belong to the current category folder
const sidebarLinks = pages.filter((page: any) => page.url.includes(`/${category}/`));
---

<nav>
  <h3>{category.toUpperCase()}</h3>
  <ul>
    {sidebarLinks.map((page: any) => (
      <li>
        <a href={page.url}>{page.frontmatter.title}</a>
      </li>
    ))}
  </ul>
</nav>