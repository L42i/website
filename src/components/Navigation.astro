---
// Top-level section links. Add a section here to add a nav item.
const categoryLinks = [
  { id: 'projects', label: 'Projects' },
  { id: 'people', label: 'People' },
  { id: 'lab', label: 'Lab' },
  { id: 'courses', label: 'Courses' },
  { id: '3d-contest', label: '3DContest' },
];
---

<div class="nav-menu-wrapper">
  <ul class="nav-links">
    {categoryLinks.map((link) => (
      <li>
        <a href={`/${link.id}`} class="nav-item">{link.label}</a>
      </li>
    ))}
  </ul>
</div>

<style>
  .nav-links {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .nav-item {
    text-decoration: none;
    color: #4b5563;
    font-size: 0.95rem;
    font-weight: 500;
    padding: 0.5rem 0.75rem;
    border-radius: 0.375rem;
    transition: all 0.2s ease-in-out;
    display: inline-block;
  }

  .nav-item:hover {
    color: #111827;
    background-color: #f3f4f6;
  }

  @media (max-width: 600px) {
    .nav-links {
      flex-wrap: wrap;
      justify-content: center;
      gap: 0.5rem;
    }
  }
</style>
