---
// src/pages/[...id].astro
// Content lives in src/content/<category>/*.md. Folders define the menu
// categories; URLs are FLAT by default (/bikes), and hierarchical only for
// the categories you opt in below (/courses/dsp).

import BaseLayout from '../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  // ── URL policy ────────────────────────────────────────────────────────────
  // Categories listed here keep their folder in the URL (e.g. /courses/dsp).
  // Every other category is served flat (e.g. /bikes). Add "events" etc. here
  // whenever you want that category to be hierarchical.
  const NESTED_CATEGORIES = new Set(['courses', 'events', '3d-contest']);
  // ──────────────────────────────────────────────────────────────────────────

  // Title fallback chain: frontmatter.title -> first H1 -> prettified slug
  const deriveTitle = (fileInstance, slug) => {
    const fm = fileInstance.frontmatter || {};
    if (fm.title) return fm.title;
    const h1 = fileInstance.getHeadings?.().find((h) => h.depth === 1);
    if (h1?.text) return h1.text;
    return slug.replace(/[-_]/g, ' ').replace(/\b\w/g, (c) => c.toUpperCase());
  };

  const markdownFiles = import.meta.glob('/src/content/**/*.{md,markdown}', {
    eager: true,
  });

  // Parse every file into a normalized entry.
  const entries = Object.entries(markdownFiles).map(([filePath, fileInstance]) => {
    const parts = filePath.split('/');
    const category = parts[parts.indexOf('content') + 1] || '';
    const slug = parts[parts.length - 1].replace(/\.(md|markdown)$/, '');
    const nested = NESTED_CATEGORIES.has(category);
    return {
      filePath,
      fileInstance,
      category,
      slug,
      // The route id: "courses/dsp" if nested, otherwise just "dsp".
      url: nested ? `${category}/${slug}` : slug,
    };
  });

  const paths = [];
  const seen = new Map(); // route id -> source file (collision guard)

  // 1. One page per markdown file.
  for (const e of entries) {
    if (e.slug === 'index') continue;
    if (seen.has(e.url)) {
      console.warn(
        `[routing] Duplicate URL "/${e.url}": keeping ${seen.get(e.url)}, ` +
          `skipping ${e.filePath}. Rename one file, or make its category nested.`
      );
      continue;
    }
    seen.set(e.url, e.filePath);
    paths.push({
      params: { id: e.url },
      props: {
        type: 'content',
        fileInstance: e.fileInstance,
        title: deriveTitle(e.fileInstance, e.slug),
      },
    });
  }

  // 2. One listing page per category folder (served at /<category>).
  const categories = [...new Set(entries.map((e) => e.category).filter(Boolean))];
  for (const category of categories) {
    if (seen.has(category)) {
      console.warn(
        `[routing] Category "/${category}" clashes with a flat page of the ` +
          `same name (${seen.get(category)}); skipping the listing page.`
      );
      continue;
    }
    const files = entries
      .filter((e) => e.category === category && e.slug !== 'index')
      .map((e) => ({
        url: e.url, // correct link target, flat or nested
        title: deriveTitle(e.fileInstance, e.slug),
        description: e.fileInstance.frontmatter?.description ?? null,
      }));
    paths.push({
      params: { id: category },
      props: { type: 'category', categoryName: category, files },
    });
  }

  return paths;
}

const { type, fileInstance, title, categoryName, files } = Astro.props;
const Content = type === 'content' ? fileInstance.Content : null;
---

{
  type === 'content' ? (
    <BaseLayout title={title}>
      <Content />
    </BaseLayout>
  ) : (
    <BaseLayout title={categoryName} variant="wide">
      <h1 class="category-title">{categoryName}</h1>
      <p class="category-subtitle">
        Browsing all available files in the {categoryName} archive.
      </p>

      {files.length === 0 ? (
        <div class="empty-state">
          <p>
            No markdown documents found in{' '}
            <code>src/content/{categoryName}/</code> yet.
          </p>
        </div>
      ) : (
        <ul class="directory-list">
          {files.map((file) => (
            <li class="directory-item">
              <a href={`/${file.url}`} class="directory-link">
                <div class="file-info">
                  <strong class="file-title">{file.title}</strong>
                  {file.description && <p class="file-desc">{file.description}</p>}
                </div>
              </a>
            </li>
          ))}
        </ul>
      )}
    </BaseLayout>
  )
}
