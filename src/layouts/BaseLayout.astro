---
// BaseLayout.astro
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

import '../styles/global.css';

// variant: 'article' (default narrow column) | 'wide' (category listings)
const { title, variant = 'article' } = Astro.props;
const mainClass = variant === 'wide' ? 'category-container' : 'content-post';
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title || 'L42i'}</title>
  </head>
  <body>
    <Header />

    <main class={mainClass}>
      <slot />
    </main>
    <Footer />

  </body>
</html>